{
  "name": "toksave",
  "version": "0.1.0",
  "type": "module",
  "description": "Cross-platform CLI that installs + wires token-saving tools into AI coding agents.",
  "author": "agungprasastia",
  "license": "MIT",
  "repository": "https://github.com/agungprasastia/toksave",
  "bin": {
    "toksave": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --compile --outfile toksave",
    "build:linux-x64": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile dist/toksave-linux-x64",
    "build:linux-arm64": "bun build ./src/index.ts --compile --target=bun-linux-arm64 --outfile dist/toksave-linux-arm64",
    "build:darwin-x64": "bun build ./src/index.ts --compile --target=bun-darwin-x64 --outfile dist/toksave-darwin-x64",
    "build:darwin-arm64": "bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/toksave-darwin-arm64",
    "build:windows-x64": "bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile dist/toksave-windows-x64.exe",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "test": "bun test",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "format": "biome format --write ./src"
  },
  "dependencies": {
    "@clack/prompts": "1.6.0",
    "adm-zip": "^0.5.18",
    "commander": "15.0.0",
    "picocolors": "^1.1.1",
    "semver": "^7.8.5",
    "smol-toml": "^1.7.0",
    "tar": "^7.5.19",
    "which": "7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "latest",
    "@types/semver": "^7.7.1",
    "@types/tar": "7.0.0",
    "@types/which": "^3.0.4",
    "typescript": "5.9.3"
  }
}
